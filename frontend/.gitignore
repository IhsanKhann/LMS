# ==============================================================
#  Backend .gitignore
# ==============================================================

# ── Environment — NEVER commit real secrets ───────────────────
.env
.env.local
.env.*.local

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime & OS ──────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
.DS_Store
Thumbs.db

# ── Coverage & testing ────────────────────────────────────────
coverage/
.nyc_output/

# ── Build output (if you ever transpile) ──────────────────────
dist/
build/