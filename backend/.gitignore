# ==============================================================
#  Frontend .gitignore (Vite + React)
# ==============================================================

# ── Environment — NEVER commit real values ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Vite build output ─────────────────────────────────────────
dist/
dist-ssr/

# ── Vite cache ────────────────────────────────────────────────
.vite/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS & editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Testing ───────────────────────────────────────────────────
coverage/